# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=

# Base URL for the backend API (leave empty to use Vite dev proxy / Vercel rewrites)
VITE_BACKEND_API_URL=

# Target for the Vite dev server's /auth, /costos, /profile proxy (leave empty for the deployed backend)
VITE_DEV_PROXY_TARGET=

# X-API-Key sent on mutating requests (POST/PUT/PATCH/DELETE) — must match
# one of the backend's API_KEYS.
VITE_API_KEY=
